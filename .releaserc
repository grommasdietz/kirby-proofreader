{
  "branches": [
    "main"
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node tools/package-release.mjs ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "dist/kirby-proofreader.zip",
            "name": "kirby-proofreader-${nextRelease.gitTag}.zip",
            "label": "Kirby Proofreader plugin ZIP"
          }
        ]
      }
    ]
  ]
}
